# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://transit:transit@db:5432/transit_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── TDX API (https://tdx.transportdata.tw → 申請免費帳號後取得) ───────────────
TDX_CLIENT_ID=your_client_id_here
TDX_CLIENT_SECRET=your_client_secret_here

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
